ACCESS_CLIENT_ID=<Copy from "Client ID" in Cloudflare Access SaaS app>
ACCESS_CLIENT_SECRET=<Copy from "Client secret" in Cloudflare Access SaaS app>
ACCESS_AUTHORIZATION_URL=<Copy from "Authorization endpoint" in Cloudflare Access SaaS app>
ACCESS_TOKEN_URL=<Copy from "Token endpoint" in Cloudflare Access SaaS app>
ACCESS_JWKS_URL=<Copy from "Key endpoint" in Cloudflare Access SaaS app>
COOKIE_ENCRYPTION_KEY=<generate with: openssl rand -hex 32>
ALLOWED_EMAIL=<your email address>